# Copy this file to .env and fill in your values
# All nodes on the same network MUST use the same DFS_ENCRYPTION_KEY

# REQUIRED: 32-byte encryption key for AES-GCM file encryption
# Generate a strong one: openssl rand -base64 32
DFS_ENCRYPTION_KEY=replace-this-with-a-real-32-byte-key!!

# OPTIONAL: transport protocol — tcp is recommended for LAN use
# Values: tcp | quic  (default: quic)
DFS_TRANSPORT=tcp

# OPTIONAL: enable mutual TLS between nodes (advanced)
# DFS_ENABLE_TLS=true

# OPTIONAL: OpenTelemetry tracing endpoint (e.g. Jaeger)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
